{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "app",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "src/Pet.Jira.Web", "--urls", "http://localhost:5050"],
      "port": 5050
    },
    {
      "name": "web-mock",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "src/Pet.Jira.Web", "--no-build", "--no-launch-profile", "--urls", "http://localhost:5050"],
      "port": 5050,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_IS_MOCK": "true"
      }
    },
    {
      "name": "mockups",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8743", "--directory", "docs/superpowers/specs/mockups"],
      "port": 8743
    }
  ]
}
