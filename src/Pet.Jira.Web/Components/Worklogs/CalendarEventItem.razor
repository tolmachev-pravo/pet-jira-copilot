@using Pet.Jira.Application.Extensions.YandexCalendar.Dto

<MudElement Class="gap-2 d-flex flex-wrap border-none align-center"
            Style="@(IsLogged ? "opacity:0.45" : "")">
    <MudElement Class="flex-auto d-flex gap-1 align-center" Style="width: 300px">
        <MudElement Style="width:28px" />@* spacer: aligns with WorklogMenu button in sibling rows *@
        <WorklogTimeRange StartDate="@Entity.Start"
                          CompleteDate="@Entity.End"
                          Color="@(IsLogged ? Color.Default : Color.Success)" />
        <MudIcon Icon="@Icons.Material.Filled.Event"
                 Color="@(IsLogged ? Color.Default : Color.Success)"
                 Size="Size.Small"
                 Class="ml-1" />
        <MudElement Class="pl-2" Style="flex:1;min-width:0;overflow:hidden">
            <MudText Typo="Typo.body2"
                     Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                @Entity.Summary
            </MudText>
        </MudElement>
        @if (Entity.JiraIssueKeyHint is not null)
        {
            <MudChip T="string" Size="Size.Small"
                     Color="@(IsLogged ? Color.Default : Color.Primary)"
                     Variant="Variant.Outlined">
                @Entity.JiraIssueKeyHint
            </MudChip>
        }
    </MudElement>
    <MudElement Class="flex-none d-flex justify-end align-center">
        @if (IsLogged)
        {
            <MudIconButton Size="Size.Small"
                           Icon="@Icons.Material.Filled.Check"
                           Color="Color.Default"
                           Disabled="true" />
        }
        else
        {
            <MudTooltip Text="Залогировать">
                <MudIconButton Size="Size.Small"
                               Icon="@Icons.Material.Filled.Add"
                               Color="Color.Success"
                               OnClick="@(() => OnLogPressed.InvokeAsync(Entity))" />
            </MudTooltip>
        }
    </MudElement>
</MudElement>
