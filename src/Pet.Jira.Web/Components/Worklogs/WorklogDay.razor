@using Pet.Jira.Web.Common
@using Pet.Jira.Application.Extensions.Dto
@using MudBlazor

<tr class="pet-table-summary-tr">
    <td>
        <MudPaper Class="gap-1 d-flex flex-wrap border-none align-center pet-paper" Elevation="0" Width="100%">
            <MudElement Class="flex-none d-flex gap-2 py-2 align-center">
                <WorklogDayMenu Entity=@Entity OnCreatedPressed="AddWorklogAsync" />
                <MudElement Style="width: 102px">
                    <MudProgressLinear Color="Color.Success" Size="Size.Small" Value="@Entity.Progress" />
                </MudElement>

                @if (Entity.HasRawEstimatedWorklogs)
                {
                    <MudBadge Content="Entity.RawEstimatedWorklogCount" Color="Color.Info" Overlap="true">
                        <WorklogDayChip Value="@Entity.Date.ToString(DateFormats.DateFormat)" />
                    </MudBadge>
                }
                else
                {
                    <WorklogDayChip Value="@Entity.Date.ToString(DateFormats.DateFormat)" />
                }
            </MudElement>
            <MudElement Class="flex-none d-flex gap-1 pet-worklog-day-chips-container pl-3">
                <WorklogDayChip Caption="Logged" Value="@Entity.ActualWorklogTimeSpent.ToString(DateFormats.TimeFormat)" />
                <WorklogDayChip Caption="Estimated" Value="@Entity.WorklogTimeSpent.ToString(DateFormats.TimeFormat)" />
                <WorklogDayChip Value="@Entity.Date.DayOfWeek.ToString()" Color="@Color" />
            </MudElement>
        </MudPaper>
    </td>
</tr>

@* Estimated worklogs — unchanged *@
@foreach (var entity in Entity.EstimatedWorklogs)
{
    <tr>
        <td>
            <WorklogItem Entity="@entity" OnAddPressed="AddWorklogAsync" />
        </td>
    </tr>
    @foreach (var child in entity.Children)
    {
        <tr>
            <td>
                <EstimatedActualWorklogItem Entity="@child" />
            </td>
        </tr>
    }
}

@* Actual worklogs merged with calendar events, sorted by time *@
@foreach (var row in _dayRows)
{
    <tr>
        <td>
            @if (row.Worklog is not null)
            {
                <ActualWorklogItem Entity="@row.Worklog" />
            }
            else if (row.CalendarEvent is not null)
            {
                <MudPaper @onclick="() => OpenCalendarWorklogDialog(row.CalendarEvent)"
                          Class="d-flex align-center gap-3 pa-2 my-1"
                          Style="cursor:pointer"
                          Elevation="0">
                    <MudText Typo="Typo.caption" Color="Color.Default" Style="min-width:52px">
                        @row.CalendarEvent.StartLocal.ToString("HH:mm")
                    </MudText>
                    <MudDivider Vertical="true" FlexItem="true" Style="border-color: var(--mud-palette-success);" />
                    <MudIcon Icon="@Icons.Material.Filled.Event" Color="Color.Success" Size="Size.Small" />
                    <MudText Typo="Typo.body2" Style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                        @row.CalendarEvent.Summary
                    </MudText>
                    @if (row.CalendarEvent.JiraIssueKeyHint is not null)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                            @row.CalendarEvent.JiraIssueKeyHint
                        </MudChip>
                    }
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Add">
                        Залогировать
                    </MudButton>
                </MudPaper>
            }
        </td>
    </tr>
}

