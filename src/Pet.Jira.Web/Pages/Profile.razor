@page "/profile"
@attribute [Authorize]

<MudStack Spacing="3">
    @if (!string.IsNullOrWhiteSpace(_model.StatusMessage))
    {
        <MudAlert Severity="@_model.StatusSeverity" Variant="Variant.Filled" Dense="true">
            @_model.StatusMessage
        </MudAlert>
    }

    <MudPaper Outlined="true" Class="pa-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudAvatar Size="Size.Large" Color="Color.Primary" Image="@_model.Avatar">
                <MudIcon Icon="@Icons.Material.Rounded.AccountCircle" />
            </MudAvatar>
            <MudStack Spacing="0">
                <MudText Typo="Typo.h5">Profile</MudText>
                <MudText Typo="Typo.body1">@_model.Username</MudText>
            </MudStack>
        </MudStack>
    </MudPaper>

    <MudPaper Outlined="true" Class="pa-4">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">Integrations</MudText>

            <MudCard Outlined="true">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.subtitle1">Yandex</MudText>
                            <MudText Typo="Typo.body2">@_model.ConnectionStatusText</MudText>
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (!string.IsNullOrWhiteSpace(_model.ExternalLogin))
                    {
                        <MudText Typo="Typo.body2">Account: @_model.ExternalLogin</MudText>
                    }

                    @if (_model.LastConnectedAtUtc.HasValue)
                    {
                        <MudText Typo="Typo.body2">Last connected (UTC): @_model.LastConnectedAtUtc.Value.ToString("yyyy-MM-dd HH:mm:ss")</MudText>
                    }

                    @if (!string.IsNullOrWhiteSpace(_model.LastError))
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Outlined" Class="mt-3">
                            @_model.LastError
                        </MudAlert>
                    }
                </MudCardContent>
                <MudCardActions>
                    @if (_model.CanConnect)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/profile/integrations/yandex/connect">
                            Подключить Yandex
                        </MudButton>
                    }

                    @if (_model.CanReconnect)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/profile/integrations/yandex/connect">
                            Переподключить
                        </MudButton>
                    }

                    @if (_model.CanDisconnect)
                    {
                        <form method="post" action="/profile/integrations/yandex/disconnect">
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Outlined" Color="Color.Error">
                                Отключить
                            </MudButton>
                        </form>
                    }
                </MudCardActions>
            </MudCard>
        </MudStack>
    </MudPaper>
</MudStack>
